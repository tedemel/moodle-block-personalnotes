{{!
    @template block_personalnotes/block_content

    Tabs + toolbar + contenteditable editor.

    Context variables:
    * contextid    (int)
    * tabs         (array) - id, tabname, notetext, active, deletable
    * viewurl      (string)
    * strviewnotes (string)
}}
<div class="block_personalnotes" data-personalnotes-context="{{contextid}}">

    {{! ── Link to full overview ── }}
    <div class="mb-2">
        <a href="{{viewurl}}" class="btn btn-sm btn-outline-secondary w-100">
            <i class="fa-solid fa-list me-1" aria-hidden="true"></i>{{strviewnotes}}
        </a>
    </div>

    {{! ── Tab bar ── }}
    <div class="personalnotes-tabbar d-flex align-items-center flex-wrap gap-1 mb-1"
         data-personalnotes-tabs>
        {{#tabs}}
        <button type="button"
                class="personalnotes-tab btn btn-sm {{#active}}active{{/active}}"
                data-tabid="{{id}}">
            <span class="personalnotes-tablabel">{{tabname}}</span>
            <span data-action="deletetab"
                  class="personalnotes-tabdelete ms-1"
                  title="{{#str}}deletetab, block_personalnotes{{/str}}"
                  aria-label="{{#str}}deletetab, block_personalnotes{{/str}}"
                  {{^deletable}}style="display:none"{{/deletable}}>&times;</span>
        </button>
        {{/tabs}}

        {{! + button }}
        <button type="button"
                class="btn btn-sm btn-outline-secondary personalnotes-addtab"
                data-action="addtab"
                title="{{#str}}addtab, block_personalnotes{{/str}}"
                aria-label="{{#str}}addtab, block_personalnotes{{/str}}">
            <i class="fa-solid fa-plus" aria-hidden="true"></i>
        </button>
    </div>

    {{! ── Formatting toolbar ── }}
    <div class="btn-group mb-1" role="toolbar"
         aria-label="{{#str}}toolbar, block_personalnotes{{/str}}"
         data-personalnotes-toolbar>
        <button type="button"
                class="btn btn-sm btn-outline-secondary"
                data-cmd="bold"
                title="{{#str}}cmd_bold, block_personalnotes{{/str}}">
            <strong>B</strong>
        </button>
        <button type="button"
                class="btn btn-sm btn-outline-secondary"
                data-cmd="insertUnorderedList"
                title="{{#str}}cmd_bullets, block_personalnotes{{/str}}">
            <i class="fa-solid fa-list-ul fa-fw" aria-hidden="true"></i>
        </button>
    </div>

    {{! ── Editor panes (one per tab) ── }}
    <div data-personalnotes-editors>
        {{#tabs}}
        <div class="form-control personalnotes-editor {{#active}}active{{/active}}"
             contenteditable="true"
             data-tabid="{{id}}"
             style="min-height:90px;overflow-y:auto;white-space:pre-wrap;{{^active}}display:none;{{/active}}"
             aria-multiline="true"
        >{{{notetext}}}</div>
        {{/tabs}}
    </div>

    <div class="text-muted small mt-1" data-personalnotes-status aria-live="polite"></div>

</div>

<style>
.personalnotes-tab {
    border: 1px solid var(--bs-border-color, #dee2e6);
    background: var(--bs-body-bg, #fff);
    border-bottom: none;
    border-radius: 4px 4px 0 0;
    padding: 2px 8px;
    font-size: 0.8rem;
}
.personalnotes-tab.active {
    background: var(--bs-primary, #0d6efd);
    color: #fff;
    border-color: var(--bs-primary, #0d6efd);
}
.personalnotes-tabdelete {
    opacity: 0.6;
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
}
.personalnotes-tabdelete:hover { opacity: 1; }
.personalnotes-editor {
    border-top-left-radius: 0;
}
</style>
