{{!
    @template block_personalnotes/view

    Full note list with search/date filter, export and print buttons.

    Context variables:
    * coursetitle   (string)
    * notes         (array)  - contextname, modname, notetext, timemodified
    * hasnotes      (bool)
    * isfiltered    (bool)
    * exporturl     (string)
    * formurl       (string)
    * q / datefrom / dateto (string) - current filter values
    * sesskey       (string)
    * backurl       (string)
    * str*          (string) - localised labels
}}
<div class="block-personalnotes-view" id="block-personalnotes-printable">

    <h2>{{#str}}viewnotes, block_personalnotes{{/str}}: {{coursetitle}}</h2>

    {{! ── Filter form ─────────────────────────────────────────────────── }}
    <form method="get" action="{{formurl}}" class="mb-4 d-print-none">
        <input type="hidden" name="courseid" value="{{#js}}{{/js}}">

        <div class="row g-2 align-items-end">

            {{! Keyword search }}
            <div class="col-12 col-md-4">
                <label for="pn-search" class="form-label small fw-semibold">
                    <i class="fa-solid fa-magnifying-glass me-1" aria-hidden="true"></i>{{strsearch}}
                </label>
                <input type="search"
                       id="pn-search"
                       name="q"
                       value="{{q}}"
                       class="form-control form-control-sm"
                       placeholder="{{strsearch}}…">
            </div>

            {{! Date from }}
            <div class="col-6 col-md-3">
                <label for="pn-datefrom" class="form-label small fw-semibold">{{strfrom}}</label>
                <input type="date"
                       id="pn-datefrom"
                       name="datefrom"
                       value="{{datefrom}}"
                       class="form-control form-control-sm">
            </div>

            {{! Date to }}
            <div class="col-6 col-md-3">
                <label for="pn-dateto" class="form-label small fw-semibold">{{strto}}</label>
                <input type="date"
                       id="pn-dateto"
                       name="dateto"
                       value="{{dateto}}"
                       class="form-control form-control-sm">
            </div>

            {{! Buttons }}
            <div class="col-12 col-md-2 d-flex gap-1">
                <button type="submit" class="btn btn-sm btn-primary flex-grow-1">
                    {{strfilter}}
                </button>
                {{#isfiltered}}
                <a href="{{formurl}}" class="btn btn-sm btn-outline-secondary" title="{{strreset}}">
                    <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                </a>
                {{/isfiltered}}
            </div>

        </div>
    </form>

    {{! ── Export / Print ─────────────────────────────────────────────── }}
    {{#hasnotes}}
    <div class="mb-3 d-flex flex-wrap gap-2 d-print-none">
        <a href="{{exporturl}}&amp;format=odt&amp;sesskey={{sesskey}}"
           class="btn btn-sm btn-outline-primary">
            <i class="fa-solid fa-file-word me-1" aria-hidden="true"></i>{{strexport}} ODT
        </a>
        <a href="{{exporturl}}&amp;format=docx&amp;sesskey={{sesskey}}"
           class="btn btn-sm btn-outline-primary">
            <i class="fa-solid fa-file-word me-1" aria-hidden="true"></i>{{strexport}} DOCX
        </a>
        <button type="button" class="btn btn-sm btn-outline-secondary"
                onclick="window.print()">
            <i class="fa-solid fa-print me-1" aria-hidden="true"></i>{{strprint}}
        </button>
    </div>

    {{! ── Note list ───────────────────────────────────────────────────── }}
    <div class="list-group">
        {{#notes}}
        <div class="list-group-item">
            <div class="d-flex w-100 justify-content-between">
                <h5 class="mb-1">
                    {{#modname}}<span class="badge bg-secondary me-1">{{modname}}</span>{{/modname}}
                    {{contextname}}
                    {{#tabname}}<span class="badge bg-light text-dark border ms-1">{{tabname}}</span>{{/tabname}}
                </h5>
                <small class="text-muted text-nowrap ms-2">{{timemodified}}</small>
            </div>
            <div class="mb-1">{{{notetext}}}</div>
        </div>
        {{/notes}}
    </div>
    {{/hasnotes}}

    {{^hasnotes}}
    <p class="text-muted">
        {{#isfiltered}}{{strnoresults}}{{/isfiltered}}
        {{^isfiltered}}{{strnonotes}}{{/isfiltered}}
    </p>
    {{/hasnotes}}

    {{! ── Back button ─────────────────────────────────────────────────── }}
    <div class="mt-3 d-print-none">
        <a href="{{backurl}}" class="btn btn-secondary">
            <i class="fa-solid fa-arrow-left me-1" aria-hidden="true"></i>{{strback}}
        </a>
    </div>

</div>

<style>
@media print {
    .d-print-none { display: none !important; }
    .block-personalnotes-view { padding: 0; }
}
</style>
